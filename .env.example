PORT=3011
DB_SERVER=localhost
DB_NAME=tarim
DB_USER=sa
DB_PASSWORD=your_password_here
# encrypt: Azure için true; yerel SQL için genelde false + trust
DB_ENCRYPT=false
DB_TRUST_CERT=true
# Otomatik guncelleme — sadece Tarim (elektrik-updates kullanilmaz)
# Bos birakilirsa: github.com/bahrikarli/tarim-updates/releases/latest/download/guncelleme.json
# Kapatmak icin: UPDATE_MANIFEST_URL=off
UPDATE_MANIFEST_URL=https://github.com/bahrikarli/tarim-updates/releases/latest/download/guncelleme.json

# EDM Bilişim e-Fatura (test) — hesap: isgelistirme@edmbilisim.com.tr
EDM_WSDL_URL=https://test.edmbilisim.com.tr/EFaturaEDM21ea/EFaturaEDM.svc?singleWsdl
EDM_USERNAME=
EDM_PASSWORD=
EDM_HOSTNAME=ACRZIRAAT
EDM_CHANNEL=ACRZIRAAT
EDM_APPLICATION=ACR Ziraat
EDM_TEST=1
# Gönderici birim etiketi (EDM portal / test hesabından)
EDM_GB_ALIAS=urn:mail:defaultgb@sirketiniz.com.tr
# Opsiyonel: ayarlardaki VKN yerine
# EDM_SENDER_VKN=
EDM_KDV_ORAN=20
EDM_FATURA_SERI=ACR
